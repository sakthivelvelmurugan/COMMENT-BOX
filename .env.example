# Example environment variables for CommentBox
# Set these in your environment or a local .env for development (do NOT commit secrets)

# Database (Postgres recommended for production)
DB_URL=jdbc:postgresql://localhost:5432/commentboxdb
DB_USERNAME=commentbox_user
DB_PASSWORD=changeme

# JWT signing secret (HS256) — set to a strong random value in production
JWT_SECRET=replace_with_strong_random_jwt_secret

# Bring-your-own-key for API key encryption (must be 32 bytes ideally)
BYOK_SECRET_KEY=replace_with_32_byte_secret_here_or_longer

# OpenRouter API key (optional; can also be saved via the UI)
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=openai/gpt-4o-mini

# CORS origins allowed (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5500

# Notes:
# - DO NOT commit real secrets to source control.
# - For local development you can leave some values blank to use H2 in-memory.
# - Ensure BYOK_SECRET_KEY is kept safe; it encrypts API keys stored in the database.
